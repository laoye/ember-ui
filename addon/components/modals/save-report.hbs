<Modal::Default @modalIsOpened={{@modalIsOpened}} @options={{@options}} @confirm={{@onConfirm}} @decline={{@onDecline}} as |options|>
    <div class="modal-body-container">
        <InputGroup @name={{t "component.save-report.report-title"}} @required={{true}}>
            <Input @value={{@options.title}} placeholder={{t "component.save-report.enter-title"}} class="form-input" />
        </InputGroup>

        <InputGroup @name={{t "common.description"}}>
            <Textarea @value={{@options.description}} placeholder={{t "component.save-report.optional-description"}} class="form-input" rows="3" />
        </InputGroup>

        <InputGroup @name={{t "common.category"}}>
            <Select @value={{@options.category}} @options={{@options.categoryOptions}} @placeholder={{t "component.save-report.select-category"}} @onChange={{@options.setCategory}} class="form-input" />
        </InputGroup>

        {{#if @options.showScheduling}}
            <div class="border-t border-gray-200 dark:border-gray-700 pt-4 mt-4">
                <div class="flex items-center mb-3">
                    <input type="checkbox" checked={{@options.isScheduled}} {{on "change" @options.toggleScheduling}} class="form-checkbox h-4 w-4 text-blue-600" />
                    <label class="ml-2 text-sm font-medium text-gray-700 dark:text-gray-300">
                        {{t "component.save-report.schedule-report"}}
                    </label>
                </div>

                {{#if @options.isScheduled}}
                    <div class="grid grid-cols-2 gap-4">
                        <InputGroup @name={{t "component.save-report.frequency"}}>
                            <Select @value={{@options.scheduleFrequency}} @options={{@options.frequencyOptions}} @onChange={{@options.setScheduleFrequency}} class="form-input" />
                        </InputGroup>

                        <InputGroup @name={{t "common.time"}}>
                            <Input @type="time" @value={{@options.scheduleTime}} class="form-input" />
                        </InputGroup>
                    </div>
                {{/if}}
            </div>
        {{/if}}
    </div>
</Modal::Default>