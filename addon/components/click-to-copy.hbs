<div class="click-to-copy" {{on "click" (fn this.copyToClipboard @value)}} ...attributes>
    <span class="click-to-copy--value">
        {{#if (has-block)}}
            {{yield}}
        {{else}}
            {{n-a @value}}
        {{/if}}
    </span>
    <span class="click-to-copy--tooltip">
        {{#if this.isCopied}}
            {{t "component.click-to-copy.copied"}}
        {{else}}
            {{t "component.click-to-copy.click-to-copy"}}
        {{/if}}
    </span>
</div>